{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "HarnessWorkflowContract",
  "type": "object",
  "required": [
    "workflow_id",
    "schema_version",
    "name",
    "objective",
    "roles",
    "gates",
    "artifacts",
    "failure_semantics",
    "execution_policy"
  ],
  "properties": {
    "workflow_id": { "type": "string", "minLength": 1 },
    "schema_version": { "const": "0.1" },
    "name": { "type": "string", "minLength": 1 },
    "objective": { "type": "string", "minLength": 1 },
    "roles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["role_id", "role_spec", "execution_spec", "output_spec", "llm_driven"],
        "properties": {
          "role_id": { "type": "string", "minLength": 1 },
          "role_spec": { "type": "string", "minLength": 1 },
          "execution_spec": { "type": "string", "minLength": 1 },
          "output_spec": { "type": "string", "minLength": 1 },
          "llm_driven": { "const": true }
        },
        "additionalProperties": false
      }
    },
    "gates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["gate_id", "condition", "required_evidence", "on_pass", "on_failure"],
        "properties": {
          "gate_id": { "type": "string", "minLength": 1 },
          "condition": { "type": "string", "minLength": 1 },
          "required_evidence": { "type": "array", "items": { "type": "string", "minLength": 1 }, "minItems": 1 },
          "on_pass": { "type": "string", "minLength": 1 },
          "on_failure": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["artifact_id", "artifact_type", "required"],
        "properties": {
          "artifact_id": { "type": "string", "minLength": 1 },
          "artifact_type": { "type": "string", "minLength": 1 },
          "required": { "type": "boolean" }
        },
        "additionalProperties": false
      }
    },
    "failure_semantics": {
      "type": "object",
      "required": ["no_fake_success", "no_silent_fallback", "explicit_failure_state"],
      "properties": {
        "no_fake_success": { "const": true },
        "no_silent_fallback": { "const": true },
        "explicit_failure_state": { "const": true }
      },
      "additionalProperties": false
    },
    "execution_policy": {
      "type": "object",
      "required": ["required_checks"],
      "properties": {
        "required_checks": { "type": "array", "items": { "type": "string", "minLength": 1 }, "minItems": 1 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
