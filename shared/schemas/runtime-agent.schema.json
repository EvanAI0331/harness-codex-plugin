{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "actionDecision",
    "capabilitySelection",
    "expectedArtifactSchema",
    "handoffSummary",
    "taskSummary",
    "upstreamArtifactIds",
    "outputFocus",
    "agentOutputDraft"
  ],
  "properties": {
    "actionDecision": {
      "enum": ["tool", "skill", "script", "compose", "handoff"]
    },
    "capabilitySelection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["capabilityType", "reason"],
      "properties": {
        "capabilityId": { "type": ["string", "null"] },
        "capabilityType": { "enum": ["tool", "skill", "script", "none"] },
        "capabilityLabel": { "type": ["string", "null"] },
        "query": { "type": ["string", "null"] },
        "reason": { "type": "string", "minLength": 1, "maxLength": 1000 }
      }
    },
    "expectedArtifactSchema": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "title", "requiredFields", "description"],
      "properties": {
        "type": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "requiredFields": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "description": { "type": "string", "minLength": 1, "maxLength": 1000 }
      }
    },
    "handoffSummary": { "type": "string", "minLength": 1, "maxLength": 1000 },
    "taskSummary": { "type": "string", "minLength": 1, "maxLength": 1000 },
    "upstreamArtifactIds": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "outputFocus": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "agentOutputDraft": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "artifactType", "contentText", "contentJson", "summary"],
      "properties": {
        "title": { "type": "string", "minLength": 1, "maxLength": 200 },
        "artifactType": { "enum": ["agent.output", "final.deliverable"] },
        "contentText": { "type": "string", "minLength": 1 },
        "contentJson": { "type": "object" },
        "summary": { "type": "string", "minLength": 1, "maxLength": 1000 }
      }
    }
  }
}
