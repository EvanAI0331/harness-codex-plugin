{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "goal",
    "constraints",
    "successCriteria",
    "perAgentAssignments",
    "finalDeliverable",
    "planningSummary"
  ],
  "properties": {
    "instruction": { "type": "string", "minLength": 1, "maxLength": 2000 },
    "goal": { "type": "string", "minLength": 1, "maxLength": 500 },
    "constraints": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "successCriteria": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "perAgentAssignments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "agentId",
          "agentRole",
          "objective",
          "expectedArtifacts",
          "dependencies",
          "capabilityFocus"
        ],
        "properties": {
          "agentId": { "type": "string", "minLength": 1 },
          "agentRole": { "type": "string", "minLength": 1 },
          "objective": { "type": "string", "minLength": 1 },
          "expectedArtifacts": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "dependencies": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "capabilityFocus": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "handoffFrom": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "finalDeliverable": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifactType",
        "ownerAgentId",
        "ownerAgentRole",
        "title",
        "format",
        "summary",
        "requiredFields"
      ],
      "properties": {
        "artifactType": { "const": "final.deliverable" },
        "ownerAgentId": { "type": "string", "minLength": 1 },
        "ownerAgentRole": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1, "maxLength": 220 },
        "format": { "type": "string", "minLength": 1, "maxLength": 200 },
        "summary": { "type": "string", "minLength": 1, "maxLength": 500 },
        "requiredFields": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "planningSummary": { "type": "string", "minLength": 1, "maxLength": 2000 }
  }
}
